{
  "name": "markdownsave",
  "version": "0.1.0",
  "description": "This extension works like a web clipper, but it downloads articles in markdown format.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/build-extension.ts --watch",
    "build": "tsx scripts/build-extension.ts",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.node.json",
    "lint": "eslint vite.config.ts vitest.config.ts playwright.config.ts eslint.config.js scripts src tests --max-warnings=0",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "package:chrome": "tsx scripts/package-chrome.ts",
    "audit:chrome": "tsx scripts/audit-chrome-build.ts"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@mozilla/readability": "^0.6.0",
    "codemirror": "^6.0.2",
    "dayjs": "^1.11.21",
    "mime": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.0.0",
    "@types/adm-zip": "^0.5.0",
    "@types/chrome": "^0.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.0.0",
    "adm-zip": "^0.5.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
